# Select backend: github (default in code) or azure
AGENT_BACKEND="github"

# Enable or disable memory across all scenarios (true/false)
USE_MEMORY=false

# Azure AI Foundry settings (required when AGENT_BACKEND=azure)
AZURE_AI_PROJECT_ENDPOINT="https://<your-project>.services.ai.azure.com/api/projects/<project-name>"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-4.1"

# GitHub Models settings (required when AGENT_BACKEND=github)
GITHUB_TOKEN="<github-token>"
# Recommended format is provider-prefixed (e.g., openai/gpt-4o-mini). The backend also accepts gpt-4o-mini.
GITHUB_MODEL="openai/gpt-4o-mini"
GITHUB_ENDPOINT="https://models.github.ai/inference"
